# MediaWiki Upload Configuration
# ================================
# Copy this file to ~/.config/mediawiki/bwhpc.conf and fill in your actual credentials.
# The target file lives outside the repo and is never committed.

[mediawiki]

# Base URL of your MediaWiki instance (no trailing slash)
url = https://wiki.bwhpc.de/e

# Target page title in the wiki (will be created if absent, updated if present)
page = NEMO2/Modules

# Local source file (generated by: make wiki)
file = wiki/Easybuild_Module_List.mediawiki

# Bot credentials — format: MainUsername@BotName
# Create a bot password at Special:BotPasswords in the wiki
username = YourUsername@BotName
password = your_bot_password_here

# Optional: edit summary shown in the page history
summary = Auto-update: EasyBuild module list (bot)
